# Required
CP_CLIENT_ID=your_oauth_client_id
CP_CLIENT_SECRET=your_oauth_client_secret
CP_ENVIRONMENT=production

# Headless / Remote (set to Pi's IP for remote OAuth callback)
# CP_CALLBACK_HOST=192.168.x.x

# Optional (override automatic OAuth flow)
# CP_ACCESS_TOKEN=manual_token
# CP_REFRESH_TOKEN=manual_refresh_token
